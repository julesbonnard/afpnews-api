{
  "name": "afpnews-api",
  "version": "2.6.0",
  "description": "Node helper functions to authenticate and fetch AFP Core API",
  "sideEffects": false,
  "main": "dist/cjs/index.cjs",
  "type": "commonjs",
  "types": "./dist/cjs/index.d.cts",
  "module": "dist/esm/index.mjs",
  "unpkg": "./dist/bundles/apicore.min.js",
  "jsdelivr": "./dist/bundles/apicore.min.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "browser": {
        "script": "./dist/bundles/apicore.min.js",
        "import": {
          "types": "./dist/esm/index.d.mts",
          "default": "./dist/bundles/apicore.min.mjs"
        },
        "require": {
          "types": "./dist/cjs/index.d.cts",
          "default": "./dist/bundles/apicore.min.js"
        }
      },
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "source": "src/index.ts",
  "files": [
    "dist",
    "Readme.md",
    "LICENSE.md"
  ],
  "scripts": {
    "clean": "rimraf dist src/grammar/index.ts",
    "build:parser": "nearleyc src/grammar/index.ne --out ./src/grammar/index.ts",
    "build": "npm run build:parser && tsdown",
    "build:watch": "npm run build:parser && tsdown --watch",
    "verify:package": "npm run build:parser && tsdown --publint --attw",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run build:parser && oxlint .",
    "prepare": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">= 12.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/julesbonnard/afpnews-api.git"
  },
  "keywords": [
    "AFP",
    "News",
    "API",
    "Node"
  ],
  "author": "Jules Bonnard",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/julesbonnard/afpnews-api/issues"
  },
  "homepage": "https://github.com/julesbonnard/afpnews-api#readme",
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@types/btoa-lite": "^1.0.2",
    "@types/events": "^3.0.3",
    "@types/moo": "^0.5.10",
    "@types/nearley": "^2.11.5",
    "@types/node": "^26.1.1",
    "@types/statuses": "^2.0.6",
    "btoa-lite": "^1.0.0",
    "events": "^3.3.0",
    "moo": "^0.5.3",
    "nearley": "^2.20.1",
    "statuses": "^2.0.2",
    "zod": "^4.4.3"
  }
}
